#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
OUT_DIR="${OUT_DIR:-${DRIFT_RESULTS_DIR:-$REPO_ROOT/out/drift}}"

if [[ -n "${TORCH_PYTHON:-}" ]]; then
  PYTHON_CMD_JSON="$(printf '["%s"]' "$TORCH_PYTHON")"
elif [[ -x "$REPO_ROOT/docker-venv/venv/bin/python" && -d "$REPO_ROOT/docker-venv/conda-python" && -f "$REPO_ROOT/scripts/host-docker-python.sh" ]]; then
  PYTHON_CMD_JSON="$(printf '["bash","%s"]' "$REPO_ROOT/scripts/host-docker-python.sh")"
elif [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
  PYTHON_CMD_JSON="$(printf '["%s"]' "$REPO_ROOT/.venv/bin/python")"
elif [[ -x "$REPO_ROOT/venv/bin/python" ]]; then
  PYTHON_CMD_JSON="$(printf '["%s"]' "$REPO_ROOT/venv/bin/python")"
else
  PYTHON_CMD_JSON='["python3"]'
fi

python3 "$REPO_ROOT/scripts/run_benchmark_matrix.py" \
  --repo-root "$REPO_ROOT" \
  --python-cmd-json "$PYTHON_CMD_JSON" \
  --out-dir "$OUT_DIR" \
  --stack-id "${STACK_ID:-rocm64_extracted_host}" \
  --reference-class "${REFERENCE_CLASS:-reference}" \
  --runtime-family "${RUNTIME_FAMILY:-rocm64_patched}" \
  --runtime-source "${RUNTIME_SOURCE:-itir:latest extracted host runtime}" \
  --workload "${WORKLOAD:-bug_report_mre}"
