    <node id="obs:kobold_rocm57_build_fixes">
      <data key="d0">KoboldCPP on ROCm 5.7 requires cudaStreamWaitEvent 3-arg fix and __hostdevice__ static fix</data>
      <data key="d1">observation</data>
      <data key="d2">known_known</data>
      <data key="d3">1.0</data>
      <data key="d4">community_tuleo1</data>
